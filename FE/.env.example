# BigStyle - Environment Variables
# Copy this file to .env (project root, next to pubspec.yaml) and fill in your values.
# Quick setup: run `bash scripts/setup.sh`

# Supabase (required)
SUPABASE_URL=https://cqzxctugvfdzaqncngaf.supabase.co
SUPABASE_ANON_KEY=sb_publishable_-ifSvQllgwBdWynP11Ga6g_5TfHBQ1C

# Flash Sale + VNPay backend URL.
# Emulator default is http://10.0.2.2:3001 (see AppConfig.apiBaseUrl).
# Physical Android device: use adb reverse or the host PC LAN IP.
FLASH_SALE_API_URL=http://localhost:3001

# Google Maps Directions REST key (required for delivery route polyline).
# This key ships inside the APK (bundled .env asset) — restrict it to the
# Directions API only, set a daily quota cap, and enable a billing alert.
# It must NOT be package/SHA-1 restricted (Google rejects that combination
# for the Directions Web Service).
GOOGLE_MAPS_API_KEY=

# The native Android Maps SDK (map tiles/markers on the Store/Delivery
# screen) uses a SEPARATE key, restricted to this app's package name +
# debug/release SHA-1. Put it in `android/local.properties` (gitignored) as:
#   GOOGLE_MAPS_API_KEY=<sdk-key>
# See app/build.gradle.kts for how it's wired into the manifest.

# Claude AI (optional - fallback to mock responses)
CLAUDE_API_KEY=

# Google client
GOOGLE_WEB_CLIENT_ID=1062727034478-skcpavfhoht9usapmjqe5hnvo9015hhg.apps.googleusercontent.com

# SePay (thanh toán chuyển khoản VietQR) — build QR ở màn thanh toán
# SEPAY_BANK: tên/mã ngân hàng theo qr.sepay.vn (vd: Vietcombank, MBBank, ACB)
# SEPAY_ACC: số tài khoản đã link vào SePay
SEPAY_BANK=
SEPAY_ACC=

# VNPay return URL the gateway redirects to after payment.
# Must match BE VNP_RETURN_URL. Secrets (TMNCODE/HASHSECRET) live on BE only.
# Emulator can leave this empty — AppConfig falls back to
#   $FLASH_SALE_API_URL/api/payments/vnpay-return
# Real device / production: use a public or ngrok URL pointing at the BE.
VNP_RETURN_URL=
